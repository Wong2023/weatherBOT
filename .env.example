# Copy to .env and fill in your values.

# ── Polymarket ────────────────────────────────────────────────────────────────
# Leave blank to let the bot auto-discover the latest London temperature market.
POLYMARKET_MARKET_ID=
POLYMARKET_BASE_URL=https://gamma-api.polymarket.com
# Optional: map outcome labels to exact temperature values.
# OUTCOME_TEMPERATURE_MAP={"Over 24°C":24,"Under 24°C":23}

# ── Signal tuning ─────────────────────────────────────────────────────────────
VALUE_TEMPERATURE_DIFF_THRESHOLD=1.2
CONSENSUS_THRESHOLD=0.75
CONSENSUS_TOLERANCE=0.4

# ── Telegram notifications (built into predict.js) ────────────────────────────
# Create a bot via @BotFather, start a chat with it, then get your chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional overrides ────────────────────────────────────────────────────────
# TARGET_DAY_OFFSET=1          # 1 = predict tomorrow (default)
# HISTORY_MAX_ENTRIES=60       # how many past predictions to use for weighting

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=4000
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme
SESSION_SECRET=change-this-to-a-long-random-string
